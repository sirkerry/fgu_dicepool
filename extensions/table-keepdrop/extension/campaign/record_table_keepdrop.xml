<?xml version="1.0" encoding="iso-8859-1"?>

<root>
	<windowclass name="table_main" merge="join">
		<sheetdata merge="add">
			<label_tabletop name="label_poolmode" insertbefore="label_output">
				<anchored width="55">
					<left anchor="right" relation="relative" offset="42" />
				</anchored>
				<static textres="tablekeepdrop_label_pool_header" />
			</label_tabletop>
			<button_stringcycler name="poolmode" insertbefore="output">
				<anchored to="leftanchor" width="60">
					<top offset="-1" />
					<left anchor="right" relation="relative" offset="20" />
				</anchored>
				<parameters>
					<defaultlabelres>tablekeepdrop_label_none</defaultlabelres>
					<labelsres>tablekeepdrop_label_keephigh|tablekeepdrop_label_keeplow|tablekeepdrop_label_drophigh|tablekeepdrop_label_droplow</labelsres>
					<values>kh|kl|dh|dl</values>
				</parameters>
			</button_stringcycler>
			<basicnumber name="poolamount" insertbefore="output">
				<anchored to="leftanchor" width="20">
					<top offset="-1" />
					<left anchor="right" relation="relative" offset="18" />
				</anchored>
			</basicnumber>
		</sheetdata>
	</windowclass>
	<windowclass name="table_main" merge="join">
		<sheetdata merge="join">
			<label_tabletop name="label_output" merge="join">
				<anchored merge="join">
					<left anchor="right" relation="relative" offset="15" />
				</anchored>
			</label_tabletop>
		</sheetdata>
	</windowclass>
</root>
